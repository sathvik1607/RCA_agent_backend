LLM_PROVIDER="custom"
LLM_MODEL="groq/openai/gpt-oss-120b"
LLM_API_KEY="..."

EMBEDDING_PROVIDER="custom"
EMBEDDING_MODEL="openrouter/nvidia/llama-nemotron-embed-vl-1b-v2:free"
EMBEDDING_API_KEY="..."
EMBEDDING_DIMENSIONS="2048"
# EMBEDDING_ENDPOINT="https://integrate.api.nvidia.com/v1"
# EMBEDDING_API_KEY="..."

# --- Neon / PostgreSQL ---
DB_PROVIDER='postgres'
DB_HOST=''
DB_PORT=5432
DB_USERNAME=''
DB_PASSWORD=''
DB_NAME=''

# --- pgvector ---
VECTOR_DB_PROVIDER='pgvector'
VECTOR_DB_HOST=''
VECTOR_DB_PORT=5432
VECTOR_DB_USERNAME=''
VECTOR_DB_PASSWORD=''
VECTOR_DB_NAME=''

ENABLE_BACKEND_ACCESS_CONTROL=false
REQUIRE_AUTHENTICATION=false
# --- Graph (store in Neon too via postgres adapter) ---
GRAPH_DATABASE_PROVIDER=postgres

# --- Pool tuning (important for Neon's pooled connections) ---
DATABASE_CONNECT_ARGS='{"statement_cache_size": 0, "prepared_statement_cache_size": 0}'
VECTOR_POOL_ARGS='{"pool_size": 2, "max_overflow": 2}'
# Limit ALL connection pools (not just vector)
POOL_ARGS='{"pool_size": 2, "max_overflow": 2, "pool_pre_ping": true, "pool_recycle": 60}'

# Disable session memory (extra LLM calls you don't need)
CACHING=false
AUTO_FEEDBACK=false
